{
  "name": "mindbridge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "npm run dev --workspace @peer-mentorship/admin",
    "dev:backend": "npm run dev --workspace @peer-mentorship/backend",
    "build": "vite build",
    "build:admin": "npm run build --workspace @peer-mentorship/admin",
    "build:backend": "npm run build --workspace @peer-mentorship/backend",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "qa:safety": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/qa-safety.ps1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "msw": "^2.13.2",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
